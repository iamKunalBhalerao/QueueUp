generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String  @id @default(uuid())
  name         String
  email        String  @unique
  password     String
  refreshToken String?

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  socialAccounts SocialAccount[]
  posts          Post[]
  medias         media[]
}

model SocialAccount {
  id                String   @id @default(cuid())
  userId            String
  platform          Platform
  platformAccountId String
  name              String
  avatarUrl         String?
  accessToken       String   @db.Text
  refreshToken      String?  @db.Text
  expiresAt         DateTime
  connectedAt       DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id])

  @@unique([userId, platform])
}

model Post {
  id       String   @id @default(cuid())
  userId   String
  platform Platform

  status PostStatus @default(DRAFT)

  scheduledAt DateTime?
  publishedAt DateTime?

  error String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  linkedInPost LinkedInPost?
}

model LinkedInPost {
  id      String   @id @default(cuid())
  postId  String   @unique
  content String   @db.Text
  media   String[] @default([])

  linkedinPostId String? // ID returned by LinkedIn after posting
  url            String? // URL of the post on LinkedIn
  publishedAt    DateTime? // Timestamp when the post was published on LinkedIn
  error          String? // Store any error message from LinkedIn API
  rawResponse    String? // Store raw API response for debugging

  post Post @relation(fields: [postId], references: [id])
}

// Add other platform-specific post models (e.g., TwitterPost, FacebookPost) as needed

model media {
  id        Int       @id @default(autoincrement())
  userId    String
  url       String    @db.Text
  type      MediaType
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

enum Platform {
  LINKEDIN
  TWITTER
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
}

enum MediaType {
  IMAGE
  VIDEO
}
